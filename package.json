{
  "name": "facebook-messenger-desktop",
  "version": "1.3.1-beta.41",
  "description": "An unofficial, self-contained desktop app for Facebook Messenger",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "npm run clean && tsc && tsc -p src/preload/tsconfig.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "start": "npm run build && node scripts/dev.js",
    "start:reset": "node scripts/reset-userdata.js && npm run build && node scripts/dev.js --reset-window",
    "generate-icons": "node scripts/generate-flat-icon-svgs.js && node scripts/generate-icons.js --force",
    "dist": "npm run build && electron-builder --config electron-builder.config.js --publish=never",
    "dist:mac": "npm run build && electron-builder --config electron-builder.config.js --mac --arm64 --x64 --publish=never",
    "dist:mac:arm": "npm run build && electron-builder --config electron-builder.config.js --mac --arm64 --publish=never",
    "dist:mac:x64": "npm run build && electron-builder --config electron-builder.config.js --mac --x64 --publish=never",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.js --win --arm64 --x64 --publish=never",
    "dist:win:arm": "npm run build && electron-builder --config electron-builder.config.js --win --arm64 --publish=never",
    "dist:win:x64": "npm run build && electron-builder --config electron-builder.config.js --win --x64 --publish=never",
    "dist:linux": "npm run build && electron-builder --config electron-builder.config.js --linux --publish=never",
    "dist:linux:arm": "npm run build && electron-builder --config electron-builder.config.js --linux --arm64 --publish=never",
    "dist:linux:x64": "npm run build && electron-builder --config electron-builder.config.js --linux --x64 --publish=never",
    "dist:all": "npm run build && electron-builder --config electron-builder.config.js --mac --win --linux --publish=never",
    "release:mac:signed": "node scripts/build-signed-macos.mjs",
    "test:ci": "npm run test:hygiene && npm run lint && npm run build && npm run test:issues && npm run test:notification && npm run test:window-open && npm run test:reload-policy && npm run test:release && npm run test:snap && npm run test:icons:local",
    "test:hygiene": "node scripts/test-repository-hygiene.js",
    "test:notification": "node -r ./scripts/register-ts.js scripts/test-notification-click.ts",
    "test:issues:deterministic": "node -r ./scripts/register-ts.js scripts/test-issues-regressions.ts",
    "test:issues": "npm run test:issues:deterministic",
    "test:window-open": "node -r ./scripts/register-ts.js scripts/test-window-open-policy.ts",
    "test:reload-policy": "node -r ./scripts/register-ts.js scripts/test-reload-policy.ts",
    "test:linux-sandbox": "node -r ./scripts/register-ts.js scripts/test-linux-sandbox-packaging.ts",
    "test:linux-artifacts": "node -r ./scripts/register-ts.js scripts/test-linux-artifacts.ts",
    "test:snap": "bash scripts/test-snap-promotion-decision.sh && bash scripts/test-verify-snap-channel-version.sh && bash scripts/test-verify-snap-channel-revisions.sh",
    "test:icons:local": "node scripts/test-icon-assets.js",
    "test:window-open:gui": "node scripts/test-window-open-gui.js",
    "test:emoji:gui": "node scripts/test-emoji-composer-gui.js",
    "test:media:modern:gui": "node scripts/test-media-click-route-gui.js --source chat --click-mode os",
    "test:subview-back:gui": "node scripts/test-archived-chat-back-gui.js",
    "test:archived-back:gui": "node scripts/test-archived-chat-back-gui.js",
    "test:requests-back:gui": "node scripts/test-archived-chat-back-gui.js --target-label \"Message requests\"",
    "test:requests-home:gui": "node scripts/test-archived-chat-back-gui.js --target-label \"Message requests\" --home-after-subview",
    "test:release:confirm": "node -r ./scripts/register-ts.js scripts/test-release-confirmation.ts",
    "test:release:mac": "node scripts/test-macos-release-contract.mjs",
    "test:release:integrity": "node -r ./scripts/register-ts.js scripts/test-release-integrity.ts",
    "test:release:winget": "node scripts/test-winget-manifests.mjs",
    "test:release": "node -r ./scripts/register-ts.js scripts/test-release-version.ts && npm run test:release:confirm && npm run test:release:integrity && npm run test:release:mac && npm run test:release:winget && npm run test:linux-sandbox"
  },
  "keywords": [
    "messenger",
    "facebook",
    "desktop",
    "electron"
  ],
  "author": {
    "name": "Alex Potenza",
    "email": "apotenza92@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "@electron/notarize": "2.5.0",
    "js-yaml": "4.3.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "@electron/asar": "3.4.1",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.57.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "electron": "40.10.6",
    "electron-builder": "26.15.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "js-yaml": "4.3.0",
    "playwright": "1.57.0",
    "png-to-ico": "^2.1.8",
    "prettier": "3.8.0",
    "sharp": "0.33.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "8.53.0"
  }
}
